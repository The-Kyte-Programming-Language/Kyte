{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Kyte Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/editors/vscode"
      ],
      "env": {
        "PATH": "${workspaceFolder}/target/debug;${workspaceFolder}/target/release;${env:PATH}"
      }
    }
  ]
}
