{
  "name": "Kyte",
  "scopeName": "source.kyte",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#anchors" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.kyte",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.kyte",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.kyte",
              "match": "\\\\[nrt\\\\\"0]"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.kyte",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.kyte",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "anchors": {
      "patterns": [
        {
          "name": "entity.name.tag.anchor.kyte",
          "match": "@\\w+"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kyte",
          "match": "\\b(if|else|for|in|loop|break|return|yield)\\b"
        },
        {
          "name": "keyword.other.kyte",
          "match": "\\b(fn|function|vault|free|kill|exit)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.kyte",
          "match": "\\b(int|float|string|bool)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.kyte",
          "match": "\\b([a-zA-Z_]\\w*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.kyte",
          "match": "(->|\\.\\.|\\.\\.|&&|\\|\\||[+\\-*/%]=?|[<>!=]=?|!)"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.kyte",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "keyword.other.anchor-kind.kyte",
          "match": "\\b(main|thread|event|plain|onerror|timeout)\\b"
        }
      ]
    }
  }
}
