/// 자릿수 세기
function count_digits(int n) -> int {
    if n == 0 {
        return 1;
    }
    int count = 0;
    int tmp = n;
    for i in 0..20 {
        if tmp > 0 {
            count += 1;
            tmp = tmp / 10;
        }
    }
    return count;
}

/// 10의 거듭제곱
function pow10(int exp) -> int {
    int result = 1;
    for i in 0..exp {
        result *= 10;
    }
    return result;
}

/// comma: 숫자를 3자리씩 끊어서 yield
/// 예: comma(1234567) -> yield 1, yield 234, yield 567
function comma(int number) -> int {
    int d = count_digits(number);
    int groups = d / 3;
    if d % 3 != 0 {
        groups += 1;
    }
    for g in 0..groups {
        int r = groups - 1 - g;
        int e = r * 3;
        int p = pow10(e);
        int chunk = number / p % 1000;
        yield chunk;
    }
    return groups;
}

/// i번째 자릿수 추출 (0 = 일의 자리)
function get_digit(int number, int pos) -> int {
    int p = pow10(pos);
    return number / p % 10;
}

/// convert: 각 자릿수를 한국어 수 읽기용 코드로 yield
/// yield 인코딩: digit * 100 + pos
///```kyte
///   digit(1~9) → 일이삼사오육칠팔구
///   pos % 4: 0=일, 1=십, 2=백, 3=천
///   pos / 4: 0=_, 1=만, 2=억, 3=조, 4=경, 5=해
///
/// 특수: digit==0이고 4자리 경계일 때 큰 단위만 yield (음수 코드)
///```
function convert(int number) -> int {
    int d = count_digits(number);
    int count = 0;
    for i in 0..d {
        int pos = d - 1 - i;
        int digit = get_digit(number, pos);
        int unit = pos % 4;
        int big = pos / 4;
        if digit != 0 {
            /// 일(1)은 십/백/천 자리에서 생략
            if digit == 1 {
                if unit != 0 {
                    int code = unit * 10 + big;
                    yield code;
                } else {
                    int code = digit * 100 + big;
                    yield code;
                }
            } else {
                int code = digit * 100 + unit * 10 + big;
                yield code;
            }
            count += 1;
        } else {
            /// 4자리 경계에서 큰 단위 표시 (만, 억, ...)
            if unit == 0 {
                if big > 0 {
                    /// 앞에 유효숫자가 있는지 확인
                    int upper = number / pow10(pos);
                    int section = upper % 10000;
                    if section > 0 {
                        int code = 0 - big;
                        yield code;
                    }
                }
            }
        }
    }
    return count;
}

@app(main)
    /// comma(1234567) → 1, 234, 567
    int g = comma(1234567);
    yield g;

    /// convert(12345) → 만이천삼백사십오
    int c = convert(12345);
    yield c;
